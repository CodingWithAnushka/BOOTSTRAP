<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pizza Hero Section</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
.hero{
    background: url("https://images.unsplash.com/photo-1513104890138-7c749659a591?auto=format&fit=crop&w=1400&q=80") no-repeat center center;
    background-size: cover;
    height: 100vh;
}

.overlay{
    background: rgba(0,0,0,0.55);
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
    color: white;
}
</style>
</head>
<body>

<section class="hero">
    <div class="overlay">
        <div class="container">
            <h1 class="display-2 fw-bold">Hot & Delicious Pizza</h1>
            <p class="lead">
                Fresh Ingredients • Cheesy Taste • Fast Delivery
            </p>
            <a href="#" class="btn btn-danger btn-lg mt-3">Order Now</a>
        </div>
    </div>
</section>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>